@model List<DontFret.Models.OrderItem>
@using DontFret.Models

@{
    ViewData["Title"] = "Refund Requests";
}

<h2>Refund Requests</h2>

<div class="mb-3">
    <a asp-action="RefundRequests" class="btn btn-sm @(Context.Request.Query["status"].Count == 0 ? "btn-primary" : "btn-outline-primary")">All</a>
    <a asp-action="RefundRequests" asp-route-status="@RefundRequestStatus.Pending" class="btn btn-sm @(Context.Request.Query["status"] == "Pending" ? "btn-primary" : "btn-outline-primary")">Pending</a>
    <a asp-action="RefundRequests" asp-route-status="@RefundRequestStatus.Approved" class="btn btn-sm @(Context.Request.Query["status"] == "Approved" ? "btn-primary" : "btn-outline-primary")">Approved</a>
    <a asp-action="RefundRequests" asp-route-status="@RefundRequestStatus.Rejected" class="btn btn-sm @(Context.Request.Query["status"] == "Rejected" ? "btn-primary" : "btn-outline-primary")">Rejected</a>
</div>

@if (Model.Count == 0)
{
    <p>No refund requests found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Order #</th>
                <th>Product</th>
                <th>Customer</th>
                <th>Reason</th>
                <th>Requested</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OrderId</td>
                    <td>@item.Product.Name</td>
                    <td>@item.Order.Customer.Email</td>
                    <td>@item.RefundReason</td>
                    <td>@item.RefundRequestedAt?.ToString("g")</td>
                    <td><span class="status-badge @GetRefundStatusClass(item.RefundStatus!.Value)">@item.RefundStatus</span></td>
                    <td>
                        @if (item.RefundStatus == RefundRequestStatus.Pending)
                        {
                            <form asp-action="ApproveRefund" method="post" style="display:inline">
                                <input type="hidden" name="orderItemId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-success">Approve</button>
                            </form>
                            <form asp-action="RejectRefund" method="post" style="display:inline">
                                <input type="hidden" name="orderItemId" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Reject</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-action="Manage" class="btn btn-primary">Back to Orders</a>
</div>

@functions {
    string GetRefundStatusClass(RefundRequestStatus status) => status switch
    {
        RefundRequestStatus.Pending => "status-refund-pending",
        RefundRequestStatus.Approved => "status-refund-approved",
        RefundRequestStatus.Rejected => "status-refund-rejected",
        _ => "bg-secondary"
    };
}
