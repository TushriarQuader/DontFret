@model DontFret.Models.User

@{
    ViewData["Title"] = "Assign Role";
}

<div class="admin-main" style="margin: -1.5rem; padding: 1.5rem;">
    <h1>Assign Role</h1>

    <form method="post" class="row g-3" style="max-width: 500px;">
        <div class="col-12">
            <p style="color: #fff;"><strong>User:</strong> @Model.Email (@Model.UserName)</p>
        </div>
        <div class="col-md-6">
            <label class="form-label">New Role</label>
            <select name="role" class="form-select">
                @foreach (var r in (List<string>)ViewData["Roles"]!)
                {
                    if (r == (string)ViewData["CurrentRole"]!)
                    {
                        <option value="@r" selected>@r</option>
                    }
                    else
                    {
                        <option value="@r">@r</option>
                    }
                }
            </select>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="ViewUsers" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
