@model List<DontFret.Models.Product>

@{
    ViewData["Title"] = "Inventory Management";
}

<div class="admin-main" style="margin: -1.5rem; padding: 1.5rem;">
    <h1>Inventory Management</h1>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Total Products</h3>
                <div class="metric-value">@ViewData["TotalProducts"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Total Stock Value</h3>
                <div class="metric-value">@(((decimal)ViewData["TotalStockValue"]!).ToString("C"))</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Low Stock Items</h3>
                <div class="metric-value" style="color: #ffc107;">@ViewData["LowStockCount"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Out of Stock</h3>
                <div class="metric-value" style="color: #dc3545;">@ViewData["OutOfStockCount"]</div>
            </div>
        </div>
    </div>

    <h3>Low Stock Alert</h3>
    @{
        var lowStockItems = Model.Where(p => p.StockQuantity > 0 && p.StockQuantity < 5).ToList();
    }
    @if (lowStockItems.Count == 0)
    {
        <p style="color: #28a745;">No low stock items.</p>
    }
    else
    {
        <table class="table mb-4">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>Category</th>
                    <th>Stock</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in lowStockItems)
                {
                    <tr>
                        <td>@p.Name</td>
                        <td>@p.Category</td>
                        <td class="stock-low">@p.StockQuantity</td>
                        <td><span class="stock-low">Low Stock</span></td>
                    </tr>
                }
            </tbody>
        </table>
    }

    <h3>All Inventory</h3>
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Category</th>
                <th>Current Stock</th>
                <th>Price</th>
                <th>Status</th>
                <th>Update Stock</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Category</td>
                    <td class="@(product.StockQuantity < 5 ? "stock-low" : product.StockQuantity < 10 ? "stock-medium" : "")">
                        @product.StockQuantity
                    </td>
                    <td>@product.Price.ToString("C")</td>
                    <td>
                        @if (product.StockQuantity == 0)
                        {
                            <span class="stock-low">Out of Stock</span>
                        }
                        else if (product.StockQuantity < 5)
                        {
                            <span class="stock-low">Low Stock</span>
                        }
                        else if (product.StockQuantity < 10)
                        {
                            <span class="stock-medium">Medium Stock</span>
                        }
                        else
                        {
                            <span class="stock-instock">In Stock</span>
                        }
                    </td>
                    <td>
                        <form asp-action="UpdateStock" method="post" class="d-flex gap-1">
                            <input type="hidden" name="productId" value="@product.Id" />
                            <input type="number" name="newStock" value="@product.StockQuantity" min="0" class="form-control" style="width: 80px;" />
                            <button type="submit" class="btn btn-sm btn-primary">Update</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-action="DashBoard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
