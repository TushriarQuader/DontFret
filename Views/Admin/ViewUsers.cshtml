@model List<(DontFret.Models.User user, IList<string> roles)>

@{
    ViewData["Title"] = "User Management";
}

<div class="admin-main" style="margin: -1.5rem; padding: 1.5rem;">
    <h1>User Management</h1>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Total Users</h3>
                <div class="metric-value">@ViewData["TotalUsers"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Admins</h3>
                <div class="metric-value" style="color: #e74c3c;">@ViewData["AdminCount"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Office Clerks</h3>
                <div class="metric-value" style="color: #3498db;">@ViewData["ClerkCount"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Customers</h3>
                <div class="metric-value" style="color: #27ae60;">@ViewData["CustomerCount"]</div>
            </div>
        </div>
    </div>

    @if (User.IsInRole("Admin"))
    {
        <p>
            <a asp-action="CreateUser" class="btn btn-primary">Create New User</a>
        </p>
    }

    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Username</th>
                <th>Phone</th>
                <th>Address</th>
                <th>Postcode</th>
                <th>Role(s)</th>
                @if (User.IsInRole("Admin"))
                {
                    <th>Actions</th>
                }
            </tr>
        </thead>
        <tbody>
            @foreach (var (user, roles) in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>@user.UserName</td>
                    <td>@user.PhoneNumber</td>
                    <td>@user.Address</td>
                    <td>@user.Postcode</td>
                    <td>
                        @foreach (var role in roles)
                        {
                            <span class="badge bg-secondary">@role</span>
                        }
                        @if (roles.Count == 0)
                        {
                            <span class="badge bg-warning">No Role</span>
                        }
                    </td>
                    @if (User.IsInRole("Admin"))
                    {
                        <td>
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="UserDetails" asp-route-id="@user.Id" class="btn btn-sm btn-secondary">Details</a>
                            <a asp-action="AssignRole" asp-route-id="@user.Id" class="btn btn-sm btn-info">Assign Role</a>
                            <a asp-action="Ban" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Ban</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-action="DashBoard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
