@model List<DontFret.Models.Product>

@{
    ViewData["Title"] = "Product Management";
}

<div class="admin-main" style="margin: -1.5rem; padding: 1.5rem;">
    <h1>Product Management</h1>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Total Products</h3>
                <div class="metric-value">@ViewData["TotalProducts"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Guitars</h3>
                <div class="metric-value">@ViewData["GuitarCount"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Amplifiers</h3>
                <div class="metric-value">@ViewData["AmpCount"]</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <h3>Accessories</h3>
                <div class="metric-value">@ViewData["AccessoryCount"]</div>
            </div>
        </div>
    </div>

    <p>
        <a asp-controller="Products" asp-action="Create" class="btn btn-primary">Create New Product</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Stock</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in Model)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Description</td>
                    <td>@product.Price.ToString("C")</td>
                    <td class="@(product.StockQuantity < 5 ? "stock-low" : product.StockQuantity < 10 ? "stock-medium" : "")">
                        @product.StockQuantity
                    </td>
                    <td>@product.Category</td>
                    <td>
                        <a asp-controller="Products" asp-action="Edit" asp-route-id="@product.Id" class="btn btn-sm btn-primary">Edit</a>
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-secondary">Details</a>
                        <a asp-controller="Products" asp-action="Delete" asp-route-id="@product.Id" class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-action="DashBoard" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
