@model DontFret.Models.User

@{
    ViewData["Title"] = "Edit User";
}

<div class="admin-main" style="margin: -1.5rem; padding: 1.5rem;">
    <h1>Edit User</h1>

    <form method="post" class="row g-3" style="max-width: 600px;">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-md-6">
            <label class="form-label">Email</label>
            <input name="email" value="@Model.Email" type="email" class="form-control" required />
        </div>
        <div class="col-md-6">
            <label class="form-label">Username</label>
            <input name="userName" value="@Model.UserName" class="form-control" />
        </div>
        <div class="col-md-6">
            <label class="form-label">Phone Number</label>
            <input name="phoneNumber" value="@Model.PhoneNumber" type="tel" class="form-control" />
        </div>
        <div class="col-12">
            <label class="form-label">Address</label>
            <input name="address" value="@Model.Address" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Postcode</label>
            <input name="postcode" value="@Model.Postcode" class="form-control" maxlength="8" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Role</label>
            <select name="role" class="form-select">
                @foreach (var r in (List<string>)ViewData["Roles"]!)
                {
                    if (r == (string)ViewData["CurrentRole"]!)
                    {
                        <option value="@r" selected>@r</option>
                    }
                    else
                    {
                        <option value="@r">@r</option>
                    }
                }
            </select>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="ViewUsers" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
