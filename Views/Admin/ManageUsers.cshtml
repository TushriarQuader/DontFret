@model List<(DontFret.Models.User user, IList<string> roles)>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="admin-main" style="margin: -1.5rem; padding: 1.5rem;">
    <h1>Manage Users</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Current Role(s)</th>
                <th>Change Role</th>
                <th>Delete</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var (user, roles) in Model)
            {
                <tr>
                    <td>@user.Email</td>
                    <td>
                        @foreach (var role in roles)
                        {
                            <span class="badge bg-secondary">@role</span>
                        }
                        @if (roles.Count == 0)
                        {
                            <span class="badge bg-warning">No Role</span>
                        }
                    </td>
                    <td>
                        <form asp-action="ChangeRole" method="post" class="d-flex gap-1">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select" style="width: auto;">
                                @foreach (var r in new[] { "Customer", "OfficeClerk", "Admin" })
                                {
                                    if (roles.Contains(r))
                                    {
                                        <option value="@r" selected>@r</option>
                                    }
                                    else
                                    {
                                        <option value="@r">@r</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Update</button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Ban @user.Email? This will remove their accound and cannot be undone.');">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
    </div>
</div>
