@model DontFret.Models.User

@{
    ViewData["Title"] = "My Profile";
}

<h1>My Profile</h1>

<form asp-action="Profile" method="post" class="row" style="max-width: 600px;">
    <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" value="@Model.Email" required />
    </div>

    <div class="mb-3">
        <label class="form-label">Address</label>
        <textarea name="address" class="form-control" rows="3" required>@Model.Address</textarea>
    </div>

    <div class="mb-3">
        <label class="form-label">Postcode</label>
        <input type="text" name="postcode" class="form-control" value="@Model.Postcode" maxlength="8" required />
    </div>

    <div class="mb-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
    </div>
</form>

<p class="mt-3">
    <a asp-area="Identity" asp-page="/Account/ChangePassword">Change Password</a>
</p>

<div class="mt-3">
    <a asp-controller="Orders" asp-action="Index" class="btn btn-secondary">Back to My Orders</a>
</div>
