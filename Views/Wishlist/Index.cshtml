@model List<DontFret.Models.WishlistItem>

@{
    ViewData["Title"] = "My Wishlist";
}

<h1>My Wishlist</h1>

@if (Model.Count == 0)
{
    <p>Your wishlist is empty. <a asp-controller="Catalogue" asp-action="Index">Browse products</a></p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Price</th>
                <th>Date Added</th>
                <th>Stock Alerts</th>
                <th>Discount Alerts</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Product.Name</td>
                    <td>@item.Product.Price.ToString("C")</td>
                    <td>@item.DateAdded.ToString("d")</td>
                    <td>
                        <form asp-action="ToggleStockAlert" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm @(item.StockAlerts ? "btn-success" : "btn-outline-secondary")">
                                @(item.StockAlerts ? "On" : "Off")
                            </button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="ToggleDiscountAlert" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-sm @(item.DiscountAlerts ? "btn-success" : "btn-outline-secondary")">
                                @(item.DiscountAlerts ? "On" : "Off")
                            </button>
                        </form>
                    </td>
                    <td>
                        <form asp-action="RemoveFromWishlist" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Remove</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <a asp-controller="Catalogue" asp-action="Index" class="btn btn-primary">Continue Shopping</a>
}
