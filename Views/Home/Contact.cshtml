@{
    ViewData["Title"] = "Contact Us";
}

<div class="container mt-4">
    <h2>Contact Us</h2>
    <div class="row mt-4">
        <div class="col-md-5">
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Our Address</h5>
                    <p class="card-text">
                        DontFret Headquarters<br>
                        13 Griffin Street<br>
                        Glasgow<br>
                        G56 8TG<br>
                        Scotland<br>
                        United Kingdom
                    </p>
                    <h5 class="card-title mt-4">Phone</h5>
                    <p class="card-text">0141 7678884</p>
                    <h5 class="card-title mt-4">Email</h5>
                    <p class="card-text">
                        General: <a href="mailto:info@dontfret.com">info@dontfret.com</a><br>
                        Support: <a href="mailto:support@dontfret.com">support@dontfret.com</a>
                    </p>
                    <h5 class="card-title mt-4">Opening Hours</h5>
                    <table class="table table-sm table-borderless">
                        <tr><td>Monday</td><td>Closed</td></tr>
                        <tr><td>Tuesday – Saturday</td><td>9:00 AM – 6:00 PM</td></tr>
                        <tr><td>Sunday</td><td>10:00 AM – 4:00 PM</td></tr>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card">
                <div class="card-body p-0">
                    <iframe
                        width="100%"
                        height="450"
                        style="border:0; display:block;"
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        src="https://www.google.com/maps?q=Glasgow&t=&z=13&output=embed">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</div>
